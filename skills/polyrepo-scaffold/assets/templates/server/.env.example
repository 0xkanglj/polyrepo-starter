# Application
# development | test | staging | production
APP_ENV=development
PORT=8080

# Log level
# Required: yes
# Allowed values: debug | info | warning | error | critical
# Default: info
LOG_LEVEL=info

# Add module-specific environment variables below
#DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
#REDIS_URL=redis://localhost:6379

# Metrics
# Required: no
# Allowed values: 0 | any non-zero port number
# Default: 0
# When 0: register GET /metrics on the main HTTP server (PORT)
# When non-zero (e.g. 9090): serve /metrics on a dedicated listener at that port
METRICS_PORT=0